# Production — SGLang on RunPod
# Replace YOUR-POD-ID with actual RunPod pod ID

# Veles 7B served by SGLang (port 30000)
VELES_BASE_URL=http://localhost:30000/v1
VELES_MODEL=veles-finance-7b
VELES_API_KEY=EMPTY

# Orchestrator llama3.1:8b served by SGLang (port 30001)
ORCHESTRATOR_BASE_URL=http://localhost:30001/v1
ORCHESTRATOR_MODEL=llama3.1-8b-instruct
ORCHESTRATOR_API_KEY=EMPTY
