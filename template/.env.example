# Environment Configuration Example

# Application Settings
APP_ENV=development
PROJECT_NAME="Veles"
VERSION=1.0.0
DEBUG=true

# API Settings
API_V1_STR=/api/v1

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# Langfuse Settings
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM Settings
OPENAI_API_KEY="your-llm-api-key" # e.g. OpenAI API key
DEFAULT_LLM_MODEL=gpt-5-mini

# Atlas Cloud (OpenAI-compatible) — alternative to OpenAI, access 59+ LLMs with one key
# Get your free key at: https://www.atlascloud.ai/console/coding-plan
# OPENAI_BASE_URL=https://api.atlascloud.ai/v1
# OPENAI_API_KEY=<your-atlascloud-key>
# DEFAULT_LLM_MODEL=deepseek-ai/deepseek-v4-pro
DEFAULT_LLM_TEMPERATURE=0.0
SESSION_NAMING_ENABLED=true

# JWT Settings
JWT_SECRET_KEY="your-jwt-secret-key"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# Database Settings
POSTGRES_HOST=db
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PORT=5432
POSTGRES_PASSWORD=mypassword
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Rate Limiting Settings
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_LOGIN="100 per minute"

# Profiling Settings
PROFILING_DIR=/tmp/fastapi_profiles
PROFILING_THRESHOLD_SECONDS=2.0

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# AWS Audit Logs (SEC Rule 17a-4 WORM compliance — optional, set to enable)
# AWS_AUDIT_BUCKET=your-worm-bucket-name
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_KMS_KEY_ID=your-kms-key-id   # optional, for KMS encryption
# AUDIT_REQUIRED=false              # set true in production to hard-fail if audit logging fails

# x402 Micropayment (USDC on Base — set PAYMENT_REQUIRED=false for free/open access)
PAYMENT_REQUIRED=false
RECEIVER_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
PAYMENT_AMOUNT_USDC=0.05
BASE_NETWORK=eip155:8453
# X402_FACILITATOR_URL=https://x402.org/facilitator
# BASE_RPC_URL=https://mainnet.base.org

# E2B Sandbox (optional — falls back to local subprocess if not set)
# E2B_API_KEY=your-e2b-key
# SANDBOX_TIMEOUT_SECONDS=30

# Streamlit Demo (for demo/app.py)
# VELES_API_URL=http://localhost:8000/api/v1

# Guided JSON repair via vLLM XGrammar (Phase 1.2 constrained decoding).
# When True: if the model misses the <output> JSON block, a fast repair call
# is made with guided_json constraint — the model cannot produce invalid JSON.
# Only active when VELES_API_URL is set. Set False to disable.
GUIDED_JSON_REPAIR_ENABLED=true
